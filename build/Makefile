main.o: main.cpp.o

.PHONY : main.o

# target to build an object file
main.cpp.o:
	$(MAKE) -f CMakeFiles/ProjectNode.dir/build.make CMakeFiles/ProjectNode.dir/main.cpp.o
.PHONY : main.cpp.o

main.i: main.cpp.i

.PHONY : main.i

# target to preprocess a source file
main.cpp.i:
	$(MAKE) -f CMakeFiles/ProjectNode.dir/build.make CMakeFiles/ProjectNode.dir/main.cpp.i
.PHONY : main.cpp.i

main.s: main.cpp.s

.PHONY : main.s

# target to generate assembly for a file
main.cpp.s:
	$(MAKE) -f CMakeFiles/ProjectNode.dir/build.make CMakeFiles/ProjectNode.dir/main.cpp.s
.PHONY : main.cpp.s

